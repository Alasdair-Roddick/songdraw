# Postgres (db service)
POSTGRES_USER=songdraw
POSTGRES_PASSWORD=songdraw
POSTGRES_DB=songdraw
DATABASE_URL=postgres://songdraw:songdraw@db:5432/songdraw

# RustFS (rustfs service) — profile picture storage
RUSTFS_ACCESS_KEY=songdraw
RUSTFS_SECRET_KEY=songdraw-dev-secret
RUSTFS_ENDPOINT=http://rustfs:9000

# cron service — must match the token the app checks on /api/internal/draw
CRON_TOKEN=changeme
